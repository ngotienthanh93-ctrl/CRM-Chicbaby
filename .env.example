# Sao chép file này thành .env rồi điền giá trị thật
PORT=4000
NODE_ENV=development

# PostgreSQL. Dev mặc định dùng container Docker (docker compose up -d) ở host port 5433.
DATABASE_URL="postgresql://crm:crm_dev_pw@localhost:5433/chicbaby_crm?schema=public"

# Bí mật phiên/cookie — production PHẢI thay bằng chuỗi ngẫu nhiên mạnh (>=32 ký tự)
SESSION_SECRET="change_me"

APP_TIMEZONE="Asia/Ho_Chi_Minh"
CLIENT_ORIGIN="http://localhost:5173"
