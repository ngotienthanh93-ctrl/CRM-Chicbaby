// CRM Chicbaby — Prisma schema (§2 SPEC-DIGEST).
// Quy ước: bảng snake_case (@@map). Cột giữ camelCase (mặc định Prisma) — raw SQL quote "camelCase".
// Soft-delete: deletedAt cho dữ liệu CRM. Optimistic lock: version cho bảng sửa đồng thời.
// KV mirror (kv_*) CHỈ ĐỌC ở tầng nghiệp vụ; chỉ worker sync/seed được ghi.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum RoleKey {
  chu_shop
  crm_officer
  cskh
  marketing
  tro_ly_du_lieu
}

enum UserStatus {
  active
  disabled
}

enum CustomerRoleType {
  retail_customer
  wholesale_contact
}

enum CustomerRoleSource {
  auto_from_kv
  manual
}

enum PreferredChannel {
  zalo
  call
  sms
}

enum RetentionStatus {
  active
  masked
}

enum PhoneType {
  primary
  zalo
  receiver
  backup
}

enum DataSource {
  KV
  CRM
}

enum SourceSystem {
  kiotviet
}

enum LinkMethod {
  auto
  manual
}

enum DatePrecision {
  exact
  month_estimated
}

enum InfoSource {
  me_ke
  bac_si_chan_doan
  nhan_vien_quan_sat
}

enum BabyAssignmentMode {
  baby_specific
  multi_audience
  not_baby_applicable
}

enum ConfidenceLevel {
  high
  medium
  low
}

enum AssignmentStatus {
  auto_assigned
  suggested
  confirmed
  customer_level
  not_applicable
}

enum AssignmentSource {
  auto_single_baby
  auto_age_match
  manual
  unassigned
}

enum OrgStatus {
  active
  slow
  at_risk
  paused
  lost
  collecting
}

enum DeclineReason {
  gia_cao
  doi_thu_chao_gia
  hang_ban_cham
  shop_het_hang
  giao_hang_cham
  cong_no
  dai_ly_dong_cua
  khong_lien_he_duoc
  khac
}

enum ReasonStatus {
  unknown
  investigating
  confirmed
  cannot_contact
}

enum EscalationLevel {
  L1
  L2
  L3
  L4
  L5
}

enum OrgContactRole {
  chu_shop
  nguoi_dat_hang
  ke_toan
  nguoi_nhan_hang
}

enum FollowUpTargetType {
  customer
  organization
}

enum ReminderType {
  consumption
  replenishment
  consultation_followup
  agency_investigation
}

enum FollowUpStatus {
