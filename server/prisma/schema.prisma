  den_han
  da_lien_he
  hen_lai
  da_mua_lai
  dong
}

enum CloseReason {
  khong_dung_nua
  doi_sp
  mua_noi_khac
  khong_phan_hoi
  be_da_lon
  khac
}

enum FrequencyCapScope {
  proactive_sales_contact
  marketing_contact
  service_contact
}

enum ClaimState {
