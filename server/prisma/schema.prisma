  claimed
  in_progress
  completed
  released
}

enum VerificationStatus {
  pending
  verified
  not_found
}

enum AttributionStatus {
  attributed
  not_attributed
}

enum CustomerReport {
  already_purchased
  intends_to_purchase
}

enum Temperature {
  nong
  am
  lanh
}

enum ConsultationResult {
  da_chot
  chua_chot
  tu_choi
}

enum ConsentStatus {
  granted
  revoked
}

enum ConsentSubjectType {
  customer
  baby
}

enum ExperimentStatus {
